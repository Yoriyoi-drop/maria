{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "Maria",
  "version": "0.1.0",
  "identifier": "ai.opencode.maria",
  "build": {
    "beforeDevCommand": "cd gui && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd gui && pnpm build",
    "frontendDist": "../gui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maria — RTL Engineering Control Center",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}